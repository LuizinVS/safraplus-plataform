# Variáveis de Ambiente para as URLs das APIs (Ambiente de Desenvolvimento Local com Docker Compose)

# Serviços Java
VITE_API_URL_AUTH=http://localhost:8081
VITE_API_URL_CAPITAL=http://localhost:8082
VITE_API_URL_NOTIFICATION=http://localhost:8083

# Serviços Python
VITE_API_URL_SCRAPER=http://localhost:8000
VITE_API_URL_RECOMMENDER=http://localhost:8002

# frontend/.env
...
VITE_NOTIFICATION_WS_URL=ws://localhost:8083/ws/notifications
...

# Controle do MSW (Mock Service Worker)
# Defina como 'false' se quiser desabilitar os mocks e testar contra o backend real
VITE_USE_MOCKS=true